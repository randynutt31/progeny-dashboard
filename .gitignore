# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging / build
build/
dist/
*.egg-info/
*.egg
.eggs/

# Test & coverage
.pytest_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# Environment / secrets
# main.py reads ANTHROPIC_API_KEY, SUPABASE_SERVICE_ROLE_KEY, FEEDING_TOKEN and
# PUSH_TOKEN from the environment; on Railway these come from service variables,
# so a .env here would only ever be local and must not be committed.
.env
.env.*
!.env.example

# Editors / IDEs
.vscode/
.idea/
*.swp

# OS
Thumbs.db
desktop.ini
.DS_Store
